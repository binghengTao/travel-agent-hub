# 注释说明：该示例环境文件列出本地和 Docker 运行需要填写的配置项。
# 复制本文件为 .env 后再填写真实配置。
# 不要提交包含真实 Key 的 .env。

# 应用基础配置。
APP_NAME=旅行助手
ENVIRONMENT=local

# 必填：管理员口令。公共知识库管理和攻略治理页面需要填写这个值。
ADMIN_TOKEN=change-me

# 登录注册配置。
# 本地运行：sqlite:///./storage/travel_assistant.db
# Docker 容器：sqlite:////app/storage/travel_assistant.db
DATABASE_URL=sqlite:///./storage/travel_assistant.db
JWT_SECRET_KEY=please-change-this-to-a-long-random-string
JWT_EXPIRE_MINUTES=10080

# 前端允许访问的地址。部署到服务器时把域名加进来。
CORS_ORIGINS=["http://localhost:5173"]

# 模型提供方。推荐 qwen，也可以使用 deepseek 或 local。
DEFAULT_PROVIDER=qwen

# Qwen / DashScope。真实演示推荐填写 DASHSCOPE_API_KEY。
DASHSCOPE_API_KEY=
QWEN_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
QWEN_CHAT_MODEL=qwen3.6-plus
QWEN_FAST_MODEL=qwen3.6-flash
QWEN_REASONING_MODEL=qwen3.6-max-preview
QWEN_EMBEDDING_MODEL=text-embedding-v4
QWEN_RERANK_MODEL=qwen3-rerank
QWEN_VISION_MODEL=qwen-vl-max-latest
QWEN_IMAGE_MODEL=qwen-image-2.0-pro
QWEN_TTS_MODEL=cosyvoice-v3-plus
QWEN_ASR_MODEL=qwen3-asr-flash-realtime

# DeepSeek。可选备用模型提供方。
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_CHAT_MODEL=deepseek-v4-flash
DEEPSEEK_REASONING_MODEL=deepseek-v4-pro

# 本地 OpenAI-compatible endpoint。可选。
# 示例：Ollama、LM Studio、vLLM、Xinference。
LOCAL_OPENAI_BASE_URL=http://localhost:11434/v1
LOCAL_OPENAI_API_KEY=local
LOCAL_CHAT_MODEL=qwen3:8b
LOCAL_EMBEDDING_MODEL=Qwen3-Embedding-0.6B

# 实时工具。完整演示推荐填写。
TAVILY_API_KEY=
AMAP_KEY=
QWEATHER_KEY=
OPENWEATHER_API_KEY=

# Redis。
# 本地运行：redis://localhost:6379/0
# Docker Compose：redis://redis:6379/0
REDIS_URL=redis://localhost:6379/0

# 运行路径。
DATASET_DIR=./data/dataset
STORAGE_DIR=./storage
CHROMA_DIR=./storage/chroma
BM25_DIR=./storage/bm25
UPLOAD_DIR=./storage/uploads
OUTPUT_DIR=./storage/outputs

# 安全、上下文和检索参数。
MAX_UPLOAD_MB=25
RATE_LIMIT_PER_MINUTE=60
SESSION_TTL_SECONDS=86400
TOOL_CACHE_TTL_SECONDS=600
MAX_CONTEXT_TOKENS=12000
RECENT_HISTORY_TOKENS=3000
MEMORY_SUMMARY_TOKENS=1500
RAG_CONTEXT_TOKENS=4000
WEB_CONTEXT_TOKENS=2500
COMPRESSION_TRIGGER_TOKENS=8000
CHUNK_SIZE=1000
CHUNK_OVERLAP=180
DENSE_TOP_K=40
BM25_TOP_K=40
RERANK_TOP_K=20
FINAL_TOP_K=6
EMBEDDING_DIMENSION=1024
